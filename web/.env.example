# ── Supabase（必填；須為非空字串。Vercel 未設定時建置會失敗，避免上線後登入錯連 localhost）──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 用球：sessions.metadata.shuttlecock_type（種類 id）、shuttlecock_brand（品牌／型號文字，選填）

# ── AI（全部選填；未設定 AI_API_BASE_URL + AI_API_KEY 時不呼叫任何外部 AI）──
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_SYSTEM_PROMPT_DEFAULT=
AI_TIMEOUT_MS=
